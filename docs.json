{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "aspen",
    "name": "Tembo Docs",
    "banner": {
        "content": "Have questions? Chat with our team in real time – open the support chat in the app.",
        "dismissible": true
    },
    "icons": {
        "library": "lucide"
    },
    "fonts": {
        "family": "Inter"
    },
    "colors": {
        "primary": "#676767",
        "light": "#FAFAFA",
        "dark": "#141414"
    },
    "background": {
        "color": {
            "light": "#F8F8F8",
            "dark": "#080808"
        }
    },
    "appearance": {
        "default": "system",
        "strict": false
    },
    "favicon": "/favicon.ico",
    "api": {
        "openapi": "/openapi.documented.yml"
    },
    "integrations": {
        "posthog": {
            "apiKey": "phc_Gx2xD1dreOAEWo4EkDeFoKMSwMsKkx6FUeMH90J97sT",
            "sessionRecording": true
        }
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Docs",
                "groups": [
                    {
                        "group": "Get Started",
                        "pages": ["index", "quickstart"]
                    },
                    {
                        "group": "Features",
                        "pages": [
                            "features/coding-agents",
                            "features/automations",
                            "features/sandbox-environment",
                            "features/feedback-loop",
                            "features/rule-files",
                            "features/hooks",
                            "features/self-hosted",
                            "features/max"
                        ]
                    },
                    {
                        "group": "Output",
                        "pages": ["features/pull-requests"]
                    },
                    {
                        "group": "Integrations",
                        "pages": [
                            "features/mcp",
                            "integrations/github",
                            "integrations/gitlab",
                            "integrations/bitbucket",
                            "integrations/slack",
                            "integrations/sentry",
                            "integrations/linear",
                            "integrations/jira",
                            "integrations/notion",
                            "integrations/postgres",
                            "integrations/aws",
                            "integrations/supabase",
                            "integrations/raycast",
                            "integrations/discord"
                        ]
                    }
                ]
            },
            {
                "tab": "API",
                "groups": [
                    {
                        "group": "Overview",
                        "pages": ["api/index"]
                    },
                    {
                        "group": "Tembo API",
                        "openapi": {
                            "source": "/openapi.documented.yml",
                            "directory": "api"
                        },
                        "pages": [
                            {
                                "group": "Tasks",
                                "pages": [
                                    "POST /task/create",
                                    "GET /task/list",
                                    "GET /task/search"
                                ]
                            },
                            {
                                "group": "Repositories",
                                "pages": ["GET /repository/list"]
                            }
                        ]
                    }
                ]
            },
            {
                "tab": "Learn",
                "groups": [
                    {
                        "group": "Use Cases",
                        "pages": [
                            "learn/fix-production-bugs",
                            "learn/implement-from-issues",
                            "learn/review-changes",
                            "learn/reduce-technical-debt",
                            "learn/keep-docs-in-sync",
                            "learn/automate-recurring-tasks"
                        ]
                    }
                ]
            }
        ]
    },
    "logo": {
        "light": "/logo/light.svg",
        "dark": "/logo/dark.svg"
    },
    "navbar": {
        "links": [
            {
                "label": "Book a Demo",
                "href": "https://book.avoma.com/tembo/tembo-demo/"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://app.tembo.io"
        }
    },
    "footer": {
        "socials": {
            "x": "https://x.com/tembo",
            "github": "https://github.com/tembo",
            "discord": "https://discord.gg/anPdgArb",
            "linkedin": "https://www.linkedin.com/company/tembo-inc/",
            "youtube": "https://www.youtube.com/@tembo_io"
        }
    },
    "redirects": []
}

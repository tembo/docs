{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "luma",
    "name": "Tembo Docs",
    "thumbnails": {
        "background": "/images/og-background.png"
    },
    "icons": {
        "library": "lucide"
    },
    "fonts": {
        "family": "Inter"
    },
    "colors": {
        "primary": "#676767",
        "light": "#FAFAFA",
        "dark": "#141414"
    },
    "background": {
        "color": {
            "light": "#F8F8F8",
            "dark": "#141414"
        }
    },
    "appearance": {
        "default": "system",
        "strict": false
    },
    "favicon": "/favicon.ico",
    "api": {
        "openapi": "openapi.documented.yml"
    },
    "integrations": {
        "posthog": {
            "apiKey": "phc_Gx2xD1dreOAEWo4EkDeFoKMSwMsKkx6FUeMH90J97sT",
            "sessionRecording": true
        }
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Docs",
                "groups": [
                    {
                        "group": "Get Started",
                        "public": true,
                        "pages": ["index", "quickstart", "support"]
                    },
                    {
                        "group": "Features",
                        "public": true,
                        "pages": [
                            "features/agents",
                            "features/models",
                            "features/feedback-loop",
                            {
                                "group": "Sandbox",
                                "pages": [
                                    "features/sandbox/overview",
                                    "features/sandbox/custom-dependencies",
                                    "features/snapshots"
                                ]
                            },
                            {
                                "group": "Self-Hosted",
                                "pages": [
                                    "features/self-hosted/overview",
                                    {
                                        "group": "Deploy",
                                        "pages": [
                                            "features/self-hosted/deploy/aws",
                                            "features/self-hosted/deploy/gcp",
                                            "features/self-hosted/deploy/azure",
                                            "features/self-hosted/deploy/kubernetes"
                                        ]
                                    },
                                    {
                                        "group": "Integrations",
                                        "pages": [
                                            "features/self-hosted/integrations/aws-storage",
                                            "features/self-hosted/integrations/azure-storage",
                                            "features/self-hosted/integrations/github",
                                            "features/self-hosted/integrations/slack"
                                        ]
                                    }
                                ]
                            },
                            {
                                "group": "Configuration",
                                "pages": [
                                    "features/agent-skills",
                                    "features/hooks",
                                    "features/model-settings",
                                    "features/rule-files"
                                ]
                            }
                        ]
                    },
                    {
                        "group": "Actions",
                        "public": true,
                        "pages": [
                            "features/agent-actions",
                            "features/pull-requests"
                        ]
                    },
                    {
                        "group": "Integrations",
                        "public": true,
                        "pages": [
                            "integrations",
                            "integrations/aws",
                            "integrations/bigquery",
                            "integrations/bitbucket",
                            "integrations/fathom",
                            "integrations/github",
                            "integrations/gitlab",
                            "integrations/hubspot",
                            "integrations/infisical",
                            "integrations/jira",
                            "integrations/linear",
                            "integrations/mcp",
                            "integrations/teams",
                            "integrations/notion",
                            "integrations/postgres",
                            "integrations/raycast",
                            "integrations/sentry",
                            "integrations/slack",
                            "integrations/snowflake",
                            "integrations/snyk",
                            "integrations/stripe",
                            "integrations/supabase"
                        ]
                    },
                    {
                        "group": "Other",
                        "public": true,
                        "pages": ["resources/pwa", "resources/pricing"]
                    }
                ]
            },
            {
                "tab": "API",
                "groups": [
                    {
                        "group": "Overview",
                        "public": true,
                        "pages": ["api/index"]
                    },
                    {
                        "group": "Tembo API",
                        "public": true,
                        "openapi": {
                            "source": "openapi.documented.yml",
                            "directory": "api"
                        },
                        "pages": [
                            {
                                "group": "Sessions",
                                "pages": [
                                    "POST /session/create",
                                    "GET /session/list",
                                    "GET /session/search"
                                ]
                            },
                            {
                                "group": "Agents",
                                "pages": ["POST /agent", "api/trigger-agent"]
                            },
                            {
                                "group": "Repositories",
                                "pages": ["GET /repository/list"]
                            }
                        ]
                    }
                ]
            },
            {
                "tab": "Learn",
                "groups": [
                    {
                        "group": "Use Cases",
                        "public": true,
                        "pages": [
                            "learn/fix-production-bugs",
                            "learn/implement-from-issues",
                            "learn/keep-docs-in-sync",
                            "learn/reduce-technical-debt",
                            "learn/review-changes"
                        ]
                    }
                ]
            }
        ]
    },
    "logo": {
        "light": "/logo/tembo-text-black.svg",
        "dark": "/logo/tembo-text-white.svg"
    },
    "navbar": {
        "links": [
            {
                "label": "Desktop App",
                "href": "https://tembo.io/download"
            },
            {
                "label": "Book a Demo",
                "href": "https://book.avoma.com/tembo/tembo-demo/"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://app.tembo.io"
        }
    },
    "footer": {
        "socials": {
            "x": "https://x.com/tembo",
            "github": "https://github.com/tembo",
            "discord": "https://discord.gg/anPdgArb",
            "youtube": "https://www.youtube.com/@tembo_io"
        }
    },
    "redirects": [
        {
            "source": "/admin/support",
            "destination": "/support"
        },
        {
            "source": "/billing",
            "destination": "/resources/pricing"
        },
        {
            "source": "/admin/billing",
            "destination": "/resources/pricing"
        },
        {
            "source": "/features/self-hosted/aws",
            "destination": "/features/self-hosted/deploy/aws"
        },
        {
            "source": "/features/self-hosted/gcp",
            "destination": "/features/self-hosted/deploy/gcp"
        },
        {
            "source": "/features/self-hosted/azure",
            "destination": "/features/self-hosted/deploy/azure"
        },
        {
            "source": "/features/automations",
            "destination": "/features/agents"
        },
        {
            "source": "/features/coding-agents",
            "destination": "/features/agents#agent-harness"
        },
        {
            "source": "/api/task/:slug",
            "destination": "/api/session/:slug"
        },
        {
            "source": "/api/trigger-automation",
            "destination": "/api/trigger-agent"
        }
    ]
}
